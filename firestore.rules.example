rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function me() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return signedIn() && (me().role in ['Founder','Admin']); }
    function isManagerOfDept(deptId) { return signedIn() && me().role == 'Manager' && me().managedDepartmentIds.hasAny([deptId]); }
    function isTeamLeadForAssignee(assignees) { return signedIn() && me().role == 'Team Lead' && assignees.hasAny(me().teamMemberIds); }
    function isAssignee(assignees) { return signedIn() && assignees.hasAny([request.auth.uid]); }

    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow write: if isAdmin();
    }

    match /taskLibrary/{taskId} {
      allow read, write: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAdmin()
        || isManagerOfDept(resource.data.departmentId)
        || isTeamLeadForAssignee(resource.data.assigneeIds)
        || isAssignee(resource.data.assigneeIds)
        || resource.data.watcherIds.hasAny([request.auth.uid]);
      allow create: if isAdmin() || isManagerOfDept(request.resource.data.departmentId);
      allow update: if isAdmin()
        || isManagerOfDept(resource.data.departmentId)
        || isTeamLeadForAssignee(resource.data.assigneeIds)
        || isAssignee(resource.data.assigneeIds);
      allow delete: if false; // soft delete only
    }

    match /attendance/{docId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create, update: if isAdmin() || request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
  }
}
